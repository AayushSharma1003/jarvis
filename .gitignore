# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Node / Frontend
node_modules/
dist/
.vite/
*.tsbuildinfo

# Rust / Tauri
target/
app/src-tauri/target/
app/src-tauri/gen/

# PyInstaller sidecar build. `dist/` above already covers backend/dist/, but
# scripts/build_sidecar.py also writes a --workpath at backend/build/ holding a
# multi-MB binary — untracked, and this environment auto-commits the working
# tree, so one sidecar build would otherwise land it in a public history.
build/

# ML model weights (huge, downloaded on install)
*.onnx
*.gguf
*.bin
*.safetensors
# NOTE: `dir/*` not `dir/`, so the `!models/README.md` re-include below works —
# git cannot re-include a file whose parent directory is itself excluded.
backend/models/*
models/*

# Local data
# *.sqlite3 matters as much as *.sqlite: the store is jarvis.sqlite3 (main.py),
# so a scratch run with JARVIS_DATA_DIR pointed inside the repo drops a file
# holding full conversation history right where git can see it.
*.sqlite
*.sqlite3
*.db
*.log

# Secrets and config
.env
.env.local
*.pem
*.key
config.local.toml

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp

# Build outputs
*.dmg
*.msi
*.exe
*.deb
*.AppImage
release/
!models/README.md
!models/.gitkeep

# Claude Code local tooling (session-specific launch config)
.claude/
